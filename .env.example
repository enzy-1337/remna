# --- Telegram ---
# Исходящий трафик через SOCKS5 (proxychains4): bot, api, tickets-bot — одинаковые переменные. На хосте должен слушать VPN/клиент (например 7891).
# В Docker по умолчанию хост: host.docker.internal (см. extra_hosts в compose). БД/Redis не проксируются (localnet в scripts/bot-entrypoint.sh).
# BOT_PROXYCHAINS_ENABLED=true
# PROXYCHAINS_SOCKS5_HOST=host.docker.internal
# PROXYCHAINS_SOCKS5_PORT=1080
# DNS через SOCKS (по умолчанию выкл. — иначе в Docker не резолвится postgres). Только если реально нужно:
# PROXYCHAINS_PROXY_DNS=true
BOT_TOKEN=
REQUIRED_CHANNEL_ID=-1001234567890
REQUIRED_CHANNEL_USERNAME=your_channel_username
BOT_USERNAME=
SUPPORT_USERNAME=
# Экран «Информация» (политика и оферта; по умолчанию — Telegra.ph)
# INFO_PRIVACY_POLICY_URL=https://telegra.ph/Politika-konfidencialnosti-08-15-17
# INFO_TERMS_OF_SERVICE_URL=https://telegra.ph/Polzovatelskoe-soglashenie-08-15-10
# Админ-лог: ID супергруппы с темами (форум). ADMIN_LOG_TOPIC_ID — запасная тема для всех типов, если отдельная не задана.
ADMIN_LOG_CHAT_ID=
ADMIN_LOG_TOPIC_ID=
# Опционально — своя тема под тип события (число id темы из Telegram). Пусто = использовать ADMIN_LOG_TOPIC_ID.
ADMIN_LOG_TOPIC_GENERAL=
ADMIN_LOG_TOPIC_PAYMENTS=
ADMIN_LOG_TOPIC_USERS=
ADMIN_LOG_TOPIC_TRIALS=
ADMIN_LOG_TOPIC_BONUSES=
ADMIN_LOG_TOPIC_SUBSCRIPTIONS=
ADMIN_LOG_TOPIC_PROMO=
ADMIN_LOG_TOPIC_DEVICES=
ADMIN_LOG_TOPIC_SUPPORT=
ADMIN_LOG_TOPIC_BACKUPS=
ADMIN_LOG_TOPIC_REPORTS=
# Сообщение «бот запущен» при старте процесса. Пусто — та же тема, что и ADMIN_LOG_TOPIC_GENERAL / ADMIN_LOG_TOPIC_ID.
ADMIN_LOG_TOPIC_BOOT=
# Ежедневный отчёт (plain-текст) в тему REPORTS, в заданный час UTC (платежи, пользователи, рефералы…)
ADMIN_REPORT_ENABLED=true
ADMIN_REPORT_HOUR_UTC=8
ADMIN_REPORT_TIMEZONE=Europe/Moscow
# Кто видит кнопку «Админ-панель» в профиле: ваш числовой Telegram ID (не username).
# Тот же id — ссылка «написать администратору» на экране «Информация» (если не задан — берётся первый из ADMIN_TELEGRAM_IDS).
# Узнать: @userinfobot, настройки Telegram (для своего id), или логи бота при /start.
ADMIN_TELEGRAM_ID=883400626
# Несколько id через запятую (не JSON). Пустая строка или отсутствие строки — ок.
ADMIN_TELEGRAM_IDS=883400626

# Ежедневный pg_dump в тему BACKUPS (нужен pg_dump в PATH на сервере бота). Час UTC.
BACKUP_ENABLED=true
BACKUP_HOUR_UTC=6
# Альтернатива UTC-часу: локальный час и таймзона (если BACKUP_HOUR_LOCAL задан, он приоритетнее).
# Для запуска в 03:00 по Москве:
# BACKUP_TIMEZONE=Europe/Moscow
# BACKUP_HOUR_LOCAL=3
# BACKUP_MAX_TELEGRAM_MB=45

INSTRUCTION_ANDROID_URL=
INSTRUCTION_IOS_URL=
INSTRUCTION_MACOS_URL=
# Telegra.ph (экраны «Инструкции»)
INSTRUCTION_TELEGRAPH_PHONE_URL=
INSTRUCTION_TELEGRAPH_PC_URL=
# Картинка для экранов профиля/подписки: путь к файлу на сервере или URL
BOT_SECTION_PHOTO_PATH=
BOT_SECTION_PHOTO_URL=

# --- PostgreSQL (asyncpg) ---
DATABASE_URL=postgresql+asyncpg://vpnbot:vpnbot@localhost:5432/vpnbot

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CHANNEL_SUB_CACHE_TTL=300

# --- Remnawave (отдельный VPS) ---
REMNAWAVE_API_URL=https://remnawave.yourdomain.com
# Если бот на том же сервере и ходит в панель по внутреннему адресу (http://127.0.0.1, docker),
# а пользователям в клиент нужен внешний домен — укажите его здесь; ссылки подписки из API будут переписаны.
# REMNAWAVE_PUBLIC_URL=https://remnawave.yourdomain.com
# Префикс API на nginx (по умолчанию /api → …/api/users). При 404 от nginx попробуйте пусто или свой путь
REMNAWAVE_API_PATH_PREFIX=/api
REMNAWAVE_API_TOKEN=
REMNAWAVE_DEFAULT_SQUAD_UUID=
REMNAWAVE_COOKIE=
REMNAWAVE_REQUEST_TIMEOUT=10
REMNAWAVE_SYNC_ENABLED=true
# false = не запускать массовый sync сразу после старта процесса
REMNAWAVE_SYNC_RUN_IMMEDIATELY=false
# 1800 = 30 минут: импорт пользователей из панели и выравнивание подписок
REMNAWAVE_SYNC_INTERVAL_SEC=1800
# Сколько записей пользователей Remnawave максимум за один проход (с пагинацией)
REMNAWAVE_SYNC_IMPORT_LIMIT=300
# Обновлять поле description в Remnawave (имя, tg, телефон из БД бота)
REMNAWAVE_SYNC_PUSH_DESCRIPTION=true
# Локально без панели: true + можно оставить пустой токен
REMNAWAVE_STUB=false
# Webhooks Remnawave (гибридный биллинг v2)
REMNAWAVE_WEBHOOKS_ENABLED=false
REMNAWAVE_WEBHOOK_SECRET=
REMNAWAVE_WEBHOOK_SIGNATURE_TTL_SEC=300
REMNAWAVE_WEBHOOK_BACKGROUND_PROCESS=true

# --- Триал ---
TRIAL_ENABLED=true
TRIAL_DURATION_DAYS=3
TRIAL_TRAFFIC_GB=1

# Стоимость одного дополнительного слота устройства (₽), шаг 8
EXTRA_DEVICE_PRICE_RUB=65

# --- Billing v2 (гибридный) ---
BILLING_V2_ENABLED=false
BILLING_V2_FOR_NEW_USERS_ONLY=true
BILLING_DEVICE_DAILY_RUB=2.5
BILLING_GB_STEP_RUB=5
BILLING_MOBILE_GB_EXTRA_RUB=2.5
BILLING_BALANCE_FLOOR_RUB=-50
BILLING_MIN_TOPUP_RUB=1
BILLING_LEGACY_LIFETIME_CUTOFF_YEAR=2099
BILLING_TRANSITION_BASE_MONTH_RUB=130
BILLING_TRANSITION_FEE_PERCENT=10
BILLING_TRANSITION_CHECK_INTERVAL_SEC=30
BILLING_DETAIL_RETENTION_DAYS=183
BILLING_NEGATIVE_NOTIFY_ENABLED=true
BILLING_NEGATIVE_NOTIFY_INTERVAL_SEC=900

# Автопродление: за SUBSCRIPTION_AUTORENEW_WINDOW_SEC до конца подписки списать цену плана «Базовый» и +30 дн.
SUBSCRIPTION_AUTORENEW_ENABLED=true
SUBSCRIPTION_AUTORENEW_INTERVAL_SEC=300
SUBSCRIPTION_AUTORENEW_WINDOW_SEC=3600

# Напоминания в Telegram за ~24 ч и ~3 ч до конца подписки/триала
SUBSCRIPTION_EXPIRY_NOTIFY_ENABLED=true
SUBSCRIPTION_EXPIRY_NOTIFY_INTERVAL_SEC=300

# Рефералы: при /start по ссылке — столько же ₽ на основной баланс и пригласившему, и приглашённому (0 = выкл.)
REFERRAL_SIGNUP_BONUS_RUB=15
# За первую платную покупку приглашённого — на каждые 30 дн. тарифа (можно старые имена REFERRAL_INVITER_BONUS_*)
REFERRAL_INVITER_REWARD_RUB_PER_30_DAYS=15
REFERRAL_INVITER_REWARD_DAYS_PER_30_DAYS=5
# 10% от всех пополнений реферала на баланс реферера
REFERRAL_TOPUP_PERCENT=10

# --- Тикет-система ---
# Токен отдельного бота тикетов (BotFather).
TICKETS_BOT_TOKEN=
# ID супергруппы (forum topics) в формате Telegram: -1001234567890
SUPPORT_GROUP_ID=-1001234567890
# Напоминания о тикетах без ответа (часы). По умолчанию 6.
REMINDER_HOURS=6
# Автозакрытие при неактивности (дни). По умолчанию 3.
AUTO_CLOSE_DAYS=3
# Макс. размер фото/видео в тикетах (MB) для Telegram и web-admin upload.
TICKETS_MEDIA_MAX_MB=50
# ADMIN_IDS: Telegram ID админов (CSV чисел через запятую).
ADMIN_IDS=

MAINTENANCE_MODE=false
LOG_LEVEL=INFO
DEBUG=false
# --- Web-admin ---
# Публичный HTTPS-origin (без слэша в конце): тот же домен, что в nginx для API/web-admin.
# В BotFather → /setdomain для этого бота — тот же хост. Нужен для Telegram Login Widget (абсолютный data-auth-url).
PUBLIC_SITE_URL=https://admin.your-domain.com
# Название и логотип в боковой панели web-admin (при пустом URL — иконка по умолчанию)
ADMIN_PANEL_TITLE=Remna
# Имя на странице «Мой профиль» в web-admin (если пусто — из Telegram/GitHub)
# WEB_ADMIN_PROFILE_DISPLAY_NAME=Enzy
# ADMIN_PANEL_LOGO_URL=https://cdn.example.com/logo.png
# Секрет cookie-сессии web-admin. В проде обязательно сменить.
WEB_ADMIN_SESSION_SECRET=change-me-in-env
# Кому разрешён вход через GitHub (логины через запятую, без @)
WEB_ADMIN_GITHUB_LOGINS=Enzy
# OAuth GitHub для web-admin (Settings -> Developer settings -> OAuth Apps)
WEB_ADMIN_GITHUB_CLIENT_ID=
WEB_ADMIN_GITHUB_CLIENT_SECRET=
# Например: https://admin.your-domain.com/admin/login/github/callback
WEB_ADMIN_GITHUB_REDIRECT_URI=

# --- Crypto Pay (@CryptoBot) ---
CRYPTOBOT_TOKEN=
CRYPTOBOT_STUB=false

# --- Platega.io (https://docs.platega.io — заголовки X-MerchantId / X-Secret) ---
PLATEGA_MERCHANT_ID=
# или старое имя:
# PLATEGA_SHOP_ID=
PLATEGA_SECRET_KEY=
PLATEGA_WEBHOOK_SECRET=
# По документации: https://app.platega.io/ (если не работает — попробуйте https://api.platega.io)
PLATEGA_API_BASE_URL=https://app.platega.io
PLATEGA_PAYMENT_METHOD=2
# Совпадают с доменом PUBLIC_SITE_URL / вашим фронтом (после оплаты)
PLATEGA_SUCCESS_URL=https://your-domain.com/payment/success
PLATEGA_FAIL_URL=https://your-domain.com/payment/fail
PLATEGA_STUB=false
# Только отладка (не в проде):
PLATEGA_SKIP_WEBHOOK_AUTH=false
