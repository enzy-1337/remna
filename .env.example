# --- Telegram ---
BOT_TOKEN=
REQUIRED_CHANNEL_ID=-1001234567890
REQUIRED_CHANNEL_USERNAME=your_channel_username
BOT_USERNAME=
SUPPORT_USERNAME=
# Админ-лог (шаг 12): ID чата/супергруппы; для форумов — ID темы
ADMIN_LOG_CHAT_ID=
ADMIN_LOG_TOPIC_ID=
# Кто видит кнопку «Админ-панель» в профиле: ваш числовой Telegram ID (не username).
# Узнать: @userinfobot, настройки Telegram (для своего id), или логи бота при /start.
# Пример: ADMIN_TELEGRAM_ID=123456789
ADMIN_TELEGRAM_ID=
# Несколько id через запятую (не JSON). Пустая строка или отсутствие строки — ок.
ADMIN_TELEGRAM_IDS=

INSTRUCTION_ANDROID_URL=
INSTRUCTION_IOS_URL=
INSTRUCTION_WINDOWS_URL=
INSTRUCTION_MACOS_URL=
# Telegra.ph (экраны «Инструкции»)
INSTRUCTION_TELEGRAPH_PHONE_URL=
INSTRUCTION_TELEGRAPH_PC_URL=
# Картинка для экранов профиля/подписки: путь к файлу на сервере или URL
BOT_SECTION_PHOTO_PATH=
BOT_SECTION_PHOTO_URL=

# --- PostgreSQL (asyncpg) ---
DATABASE_URL=postgresql+asyncpg://vpnbot:vpnbot@localhost:5432/vpnbot

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CHANNEL_SUB_CACHE_TTL=300

# --- Remnawave (отдельный VPS) ---
REMNAWAVE_API_URL=https://remnawave.yourdomain.com
# Префикс API на nginx (по умолчанию /api → …/api/users). При 404 от nginx попробуйте пусто или свой путь
REMNAWAVE_API_PATH_PREFIX=/api
REMNAWAVE_API_TOKEN=
REMNAWAVE_DEFAULT_SQUAD_UUID=
REMNAWAVE_COOKIE=
REMNAWAVE_REQUEST_TIMEOUT=10
# Локально без панели: true + можно оставить пустой токен
REMNAWAVE_STUB=false

# --- Триал ---
TRIAL_DURATION_DAYS=3
TRIAL_TRAFFIC_GB=1

# Стоимость одного дополнительного слота устройства (₽), шаг 8
EXTRA_DEVICE_PRICE_RUB=65

# Рефералы (шаг 9): награда пригласившему за первую платную покупку приглашённого (0 = выкл.)
REFERRAL_INVITER_BONUS_RUB=50
REFERRAL_INVITER_BONUS_DAYS=0

MAINTENANCE_MODE=false
LOG_LEVEL=INFO
DEBUG=false

# --- Crypto Pay (@CryptoBot) ---
CRYPTOBOT_TOKEN=
CRYPTOBOT_STUB=false

# --- Platega.io (https://api.platega.io) ---
PLATEGA_MERCHANT_ID=
# или старое имя:
# PLATEGA_SHOP_ID=
PLATEGA_SECRET_KEY=
PLATEGA_WEBHOOK_SECRET=
PLATEGA_API_BASE_URL=https://api.platega.io
PLATEGA_PAYMENT_METHOD=2
PLATEGA_SUCCESS_URL=https://yourdomain.com/payment/success
PLATEGA_FAIL_URL=https://yourdomain.com/payment/fail
PLATEGA_STUB=false
# Только отладка (не в проде):
PLATEGA_SKIP_WEBHOOK_AUTH=false
